  { "scrittura": "ごちそうさまでした", "lettura": "ごちそうさまでした", "it": ["grazie per il pasto (a fine pasto)"], "en": ["thank you for the meal"], "livello": "N5", "esempio": { "jp": "ごちそうさまでした。おいしかったです。", "it": "Grazie per il pasto, era buonissimo." } },
  { "scrittura": "おじゃまします", "lettura": "おじゃまします", "it": ["permesso (entrando in casa altrui)"], "en": ["excuse me for intruding"], "livello": "N5", "esempio": { "jp": "どうぞ。— おじゃまします。", "it": "Prego, entra. — Permesso." } },
  { "scrittura": "お久しぶりです", "lettura": "おひさしぶりです", "it": ["quanto tempo!", "è da tanto che non ci vediamo"], "en": ["long time no see"], "livello": "N5", "esempio": { "jp": "お久しぶりです。お元気でしたか。", "it": "Quanto tempo! Come sei stato?" } },
