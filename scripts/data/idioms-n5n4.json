  { "scrittura": "お腹が空いた", "lettura": "おなかがすいた", "it": ["ho fame"], "en": ["I'm hungry"], "livello": "N5", "esempio": { "jp": "お腹が空いた。何か食べよう。", "it": "Ho fame. Mangiamo qualcosa." } },
  { "scrittura": "喉が渇いた", "lettura": "のどがかわいた", "it": ["ho sete"], "en": ["I'm thirsty"], "livello": "N5", "esempio": { "jp": "喉が渇いた。水をください。", "it": "Ho sete. Dell'acqua, per favore." } },
  { "scrittura": "頑張って", "lettura": "がんばって", "it": ["forza!", "impegnati", "in bocca al lupo"], "en": ["good luck", "do your best"], "livello": "N5", "esempio": { "jp": "明日、しけんです。— 頑張って！", "it": "Domani ho l'esame. — In bocca al lupo!" } },
  { "scrittura": "おめでとうございます", "lettura": "おめでとうございます", "it": ["congratulazioni", "auguri"], "en": ["congratulations"], "livello": "N5", "esempio": { "jp": "たんじょうび、おめでとうございます。", "it": "Buon compleanno!" } },
  { "scrittura": "お先に失礼します", "lettura": "おさきにしつれいします", "it": ["vado via prima io (in ufficio)"], "en": ["excuse me for leaving first"], "livello": "N4", "esempio": { "jp": "五時ですね。お先に失礼します。", "it": "Sono le cinque. Vado via prima io." } },
  { "scrittura": "ただいま", "lettura": "ただいま", "it": ["sono a casa!"], "en": ["I'm home"], "livello": "N5", "esempio": { "jp": "ただいま。— おかえりなさい。", "it": "Sono a casa! — Bentornato." } },
  { "scrittura": "おかえりなさい", "lettura": "おかえりなさい", "it": ["bentornato"], "en": ["welcome home"], "livello": "N5", "esempio": { "jp": "ただいま。— おかえりなさい。ごはんできてるよ。", "it": "Sono a casa! — Bentornato, la cena è pronta." } },
