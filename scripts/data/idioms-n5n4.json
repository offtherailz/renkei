[
  { "scrittura": "よろしくお願いします", "lettura": "よろしくおねがいします", "it": ["piacere di conoscerti", "conto su di te"], "en": ["nice to meet you", "please treat me well"], "livello": "N5", "esempio": { "jp": "田中です。よろしくお願いします。", "it": "Sono Tanaka. Piacere." } },
  { "scrittura": "〜さんによろしくお伝えください", "lettura": "〜さんによろしくおつたえください", "it": ["salutamelo/salutala da parte mia", "porti i miei saluti a... (una terza persona assente)"], "en": ["please give my regards to ...", "say hello to ... for me"], "livello": "N4", "esempio": { "jp": "田中さんによろしくお伝えください。", "it": "Porti tanti saluti a Tanaka da parte mia." } },
