  { "scrittura": "お大事に", "lettura": "おだいじに", "it": ["rimettiti presto", "riguardati"], "en": ["get well soon"], "livello": "N5", "esempio": { "jp": "かぜですか。お大事に。", "it": "Hai il raffreddore? Rimettiti presto." } },
